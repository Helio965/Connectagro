# Ambiente
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=troque-esta-chave-em-producao

# ---------------------------------------------------------------------------
# Banco de dados
# - DATABASE_URL é usada pela aplicação (sem ela, o fallback é SQLite local).
# - DIRECT_URL é opcional: usada por migrations/conexão direta em provedores
#   com pooler (Supabase: app na porta 6543, conexão direta na 5432).
# - URLs postgres:// e postgresql:// são normalizadas automaticamente para
#   postgresql+psycopg2://, e parâmetros de pooler (pgbouncer, ...) removidos.
# - Este arquivo é um exemplo; o .env real NUNCA deve ser commitado.
# ---------------------------------------------------------------------------

# SQLite local (desenvolvimento/testes)
DATABASE_URL=sqlite:///connectagro.db

# PostgreSQL/Supabase (produção/desenvolvimento avançado) — sem credenciais reais
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:6543/postgres
# DIRECT_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/postgres

# ---------------------------------------------------------------------------
# E-mail transacional (convite de definição de senha e recuperação)
# - MAIL_ATIVO=true só tem efeito se servidor, usuário, senha e sender
#   estiverem preenchidos; sem isso o sistema não envia e-mail real.
# - Em desenvolvimento sem SMTP, o link aparece em tela se
#   PASSWORD_RESET_SHOW_DEV_LINK=true. Em produção o link nunca aparece.
# ---------------------------------------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=ConnectAgro <nao-responda@connectagro.local>
MAIL_ATIVO=false
# Validade do link de convite (minutos; padrão 1440 = 24h)
PASSWORD_INVITE_TOKEN_MINUTES=1440
# URL pública/base usada para montar links de e-mail
APP_BASE_URL=http://127.0.0.1:5000

UPLOAD_FOLDER=instance/uploads
MAX_CONTENT_LENGTH=16777216
WTF_CSRF_ENABLED=true
# Recuperação de senha (Fase 7.2): validade do token em minutos.
PASSWORD_RESET_TOKEN_MINUTES=30
# Exibe o link de redefinição na própria tela — APENAS para uso local/dev.
# Não há envio real de e-mail nesta fase; em produção deve ser false.
PASSWORD_RESET_SHOW_DEV_LINK=true
