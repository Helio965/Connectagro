# ===========================================================================
# ConnectAgro — .gitignore (projeto Python/Flask + SQLite)
# ===========================================================================

# ---------------------------------------------------------------------------
# Python — bytecode e build
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------------------------------------------------------
# Ambientes virtuais
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.virtualenv/
.python-version

# ---------------------------------------------------------------------------
# Flask
# ---------------------------------------------------------------------------
instance/
.webassets-cache
flask_session/

# ---------------------------------------------------------------------------
# Banco de dados (SQLite) — não versionar bancos locais
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# ---------------------------------------------------------------------------
# Variáveis de ambiente e segredos
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
credentials.json

# ---------------------------------------------------------------------------
# Uploads / arquivos enviados em tempo de execução
# (manter a pasta versionada com .gitkeep, ignorar o conteúdo)
# ---------------------------------------------------------------------------
uploads/
src/uploads/
src/static/uploads/
media/
!**/.gitkeep

# ---------------------------------------------------------------------------
# Testes, cobertura e ferramentas de qualidade
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# IDEs e editores
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.bak

# ---------------------------------------------------------------------------
# Node / ferramentas de frontend (caso usadas no futuro)
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# Sistema operacional
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Jupyter / notebooks
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
